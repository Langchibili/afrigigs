{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },

    "is_anonymous": {
      "type": "boolean",
      "default": false
    },
    "is_verified_human": {
      "type": "boolean",
      "default": false
    },
    "profile_completion_skilled": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 100
    },
    "profile_completion_professional": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 100
    },
    "trust_score_yes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "native_last_city": {
      "type": "string"
    },
    "country": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country",
      "inversedBy": "users"
    },
    "skilled_profile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::skilled-profile.skilled-profile",
      "mappedBy": "user"
    },
    "professional_profile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::professional-profile.professional-profile",
      "mappedBy": "user"
    },
    "wallet": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::wallet.wallet",
      "mappedBy": "user"
    },
    "posted_jobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::job.job",
      "mappedBy": "owner"
    },
    "bids": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::bid.bid",
      "mappedBy": "user"
    },
    "verification_submissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::verification-submission.verification-submission",
      "mappedBy": "user"
    }
  }
}
