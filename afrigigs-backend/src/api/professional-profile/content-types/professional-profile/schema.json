{
  "kind": "collectionType",
  "collectionName": "professional_profiles",
  "info": {
    "singularName": "professional-profile",
    "pluralName": "professional-profiles",
    "displayName": "Professional Profile",
    "description": "White-collar / professional services worker profile"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "resume_file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "education_history": {
      "type": "json",
      "default": []
    },
    "certifications": {
      "type": "component",
      "repeatable": true,
      "component": "profile.certification"
    },
    "experience_summary": {
      "type": "text"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "professional_profile"
    }
  }
}
