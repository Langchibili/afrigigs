{
  "kind": "collectionType",
  "collectionName": "escrow_transactions",
  "info": {
    "singularName": "escrow-transaction",
    "pluralName": "escrow-transactions",
    "displayName": "Escrow Transaction",
    "description": "Funds held/released for a job"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "job": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::job.job",
      "inversedBy": "escrow_transactions"
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::currency.currency"
    },
    "gateway": {
      "type": "enumeration",
      "enum": ["paystack", "flutterwave", "dpo"],
      "required": true
    },
    "gateway_ref": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["funded", "held", "released", "refunded", "failed"],
      "default": "funded",
      "required": true
    }
  }
}
