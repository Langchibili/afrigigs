{
  "kind": "collectionType",
  "collectionName": "skilled_profiles",
  "info": {
    "singularName": "skilled-profile",
    "pluralName": "skilled-profiles",
    "displayName": "Skilled Profile",
    "description": "Blue-collar / manual trades / digital services worker profile"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "national_id_number": {
      "type": "string",
      "required": true,
      "private": true
    },
    "skills_category": {
      "type": "enumeration",
      "enum": [
        "Manual Trades",
        "Digital Services",
        "Domestic Services",
        "Transport & Logistics",
        "Creative & Media",
        "Professional Services"
      ],
      "required": true
    },
    "skills": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skills-catalog.skills-catalog",
      "inversedBy": "skilled_profiles"
    },
    "description": {
      "type": "text"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "skilled_profile"
    }
  }
}
