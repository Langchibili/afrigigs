{
  "kind": "collectionType",
  "collectionName": "bids",
  "info": {
    "singularName": "bid",
    "pluralName": "bids",
    "displayName": "Bid",
    "description": "A worker's bid on a job"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "job": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::job.job",
      "inversedBy": "bids"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "bids"
    },
    "proposed_amount_local": {
      "type": "decimal"
    },
    "proposed_amount_usd": {
      "type": "decimal"
    },
    "message": {
      "type": "text"
    },
    "bid_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "withdrawn"
      ],
      "default": "pending",
      "required": true
    }
  }
}