{
  "kind": "collectionType",
  "collectionName": "countries",
  "info": {
    "singularName": "country",
    "pluralName": "countries",
    "displayName": "Country",
    "description": "Localization + currency + gig terminology per country"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "iso_code": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 2,
      "minLength": 2,
      "regex": "^[A-Z]{2}$"
    },
    "currency": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::currency.currency",
      "inversedBy": "country"
    },
    "cities": {
      "type": "json",
      "default": []
    },
    "gig_local_term_singular": {
      "type": "string",
      "default": "Gig"
    },
    "gig_local_term_plural": {
      "type": "string",
      "default": "Gigs"
    },
    "users": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "country"
    },
    "jobs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::job.job",
      "mappedBy": "country"
    }
  }
}